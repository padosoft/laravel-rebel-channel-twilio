# ============================================================================
# laravel-rebel-channel-twilio — environment variables
# ============================================================================

# --- Twilio credentials (from the Twilio Console) ---------------------------
# Account SID + Auth Token: Console home page (https://console.twilio.com).
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
# Verify Service SID (starts with "VA"): Console → Verify → Services → create one.
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Auto-register the Twilio provider into the Rebel Channels registry (needs the 3 values above).
REBEL_TWILIO_REGISTER=true

# --- Delivery status webhook ------------------------------------------------
# Records Twilio delivery receipts (delivered / failed / cost) into the Rebel
# audit trail. Set the StatusCallback URL in Twilio to:
#     https://<your-host>/rebel/twilio/status
REBEL_TWILIO_WEBHOOK=true
REBEL_TWILIO_WEBHOOK_VALIDATE=true
REBEL_TWILIO_WEBHOOK_PATH=rebel/twilio/status

# --- Live test suite (opt-in: SENDS A REAL MESSAGE) -------------------------
# Set to 1 and provide a test phone to run tests/Live against the real API.
REBEL_TWILIO_LIVE=0
TWILIO_TEST_PHONE=+391234567890
