{
  "name": "padosoft/laravel-rebel-channel-twilio",
  "description": "Twilio provider for Laravel Rebel Channels: phone verification via Twilio Verify (SMS/WhatsApp/voice), message delivery, and signed delivery-status webhooks. Part of padosoft/laravel-rebel-*.",
  "license": "MIT",
  "keywords": [
    "laravel",
    "authentication",
    "twilio",
    "verify",
    "sms",
    "whatsapp",
    "padosoft",
    "rebel"
  ],
  "homepage": "https://github.com/padosoft/laravel-rebel-channel-twilio",
  "authors": [
    {
      "name": "Padosoft",
      "email": "support@padosoft.com",
      "homepage": "https://www.padosoft.com"
    }
  ],
  "require": {
    "php": "^8.3",
    "illuminate/contracts": "^12.0|^13.0",
    "illuminate/support": "^12.0|^13.0",
    "spatie/laravel-package-tools": "^1.92",
    "padosoft/laravel-rebel-core": "^0.1",
    "padosoft/laravel-rebel-channels": "^0.1",
    "twilio/sdk": "^8.3"
  },
  "require-dev": {
    "larastan/larastan": "^3.0",
    "laravel/pint": "^1.18",
    "orchestra/testbench": "^10.0|^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0"
  },
  "repositories": [
    { "type": "vcs", "url": "https://github.com/padosoft/laravel-rebel-core" },
    { "type": "vcs", "url": "https://github.com/padosoft/laravel-rebel-channels" }
  ],
  "autoload": {
    "psr-4": {
      "Padosoft\\Rebel\\Channel\\Twilio\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Padosoft\\Rebel\\Channel\\Twilio\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Padosoft\\Rebel\\Channel\\Twilio\\RebelTwilioServiceProvider"
      ]
    }
  },
  "scripts": {
    "test": "pest",
    "phpstan": "phpstan analyse --memory-limit=512M",
    "pint": "pint",
    "check": [
      "pint --test",
      "@phpstan",
      "@test"
    ]
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "phpstan/extension-installer": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
